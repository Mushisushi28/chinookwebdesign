{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/pricing/?",
      "dest": "/pricing.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
